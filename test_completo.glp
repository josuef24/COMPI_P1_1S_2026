// ======================================================
// ARCHIVO DE PRUEBA COMPLETO - GOLAMPI INTERPRETER
// Cubre todos los rubros de la hoja de calificación
// ======================================================

// ---- VARIABLES GLOBALES (declaración larga) ----
var entero int32 = 42
var decimal float32 = 3.14
var bandera bool = true
var caracter rune = 'G'
var cadena string = "Golampi"

// ---- CONSTANTES ----
const PI float32 = 3.14159
const MAX int32 = 100

// ---- FUNCIÓN SIN PARÁMETROS (imprimirArbol) ----
func imprimirArbol() {
    fmt.Println("   *")
    fmt.Println("  ***")
    fmt.Println(" *****")
    fmt.Println("*******")
    fmt.Println("   |")
}

// ---- FUNCIÓN CON PARÁMETROS NO RECURSIVA (calcularVolumenPiramide) ----
func calcularVolumenPiramide(base float32, altura float32) float32 {
    return (base * base * altura) / 3.0
}

// ---- FUNCIÓN RECURSIVA CON UN RETORNO (potencia) ----
func potencia(base int32, exp int32) int32 {
    if exp == 0 {
        return 1
    }
    return base * potencia(base, exp - 1)
}

// ---- FUNCIÓN NO RECURSIVA MÚLTIPLE RETORNO (division) ----
func division(a int32, b int32) (int32, bool) {
    if b == 0 {
        return 0, false
    }
    return a / b, true
}

// ---- FUNCIÓN RECURSIVA MÚLTIPLE RETORNO (Algoritmo de Euclides) ----
func euclidesGCD(a int32, b int32) (int32, int32) {
    if b == 0 {
        return a, 0
    }
    gcd, pasos := euclidesGCD(b, a % b)
    return gcd, pasos + 1
}

// ---- FUNCIONES POR REFERENCIA (intercambioValores) ----
func intercambioValores(a *int32, b *int32) {
    var temp int32 = *a
    *a = *b
    *b = temp
}

// ---- FUNCIÓN POR REFERENCIA (ordenamientoSeleccion) ----
func ordenamientoSeleccion(arr *[5]int32, n int32) {
    for i := 0; i < n; i++ {
        var minIdx int32 = i
        for j := i + 1; j < n; j++ {
            if (*arr)[j] < (*arr)[minIdx] {
                minIdx = j
            }
        }
        if minIdx != i {
            intercambioValores(&(*arr)[i], &(*arr)[minIdx])
        }
    }
}

// ---- FUNCIÓN MAIN ----
func main() {
    fmt.Println("========================================")
    fmt.Println("  PRUEBA COMPLETA GOLAMPI INTERPRETER")
    fmt.Println("========================================")

    // ===== 1. FUNCIONALIDADES BÁSICAS =====
    fmt.Println("")
    fmt.Println("--- 1.1 Declaración larga de variables ---")
    var a int32 = 10
    var b float32 = 2.5
    var c bool = false
    var d rune = 'Z'
    var e string = "Hola"
    fmt.Println(a, b, c, d, e)

    fmt.Println("--- 1.2 Asignación de variables ---")
    a = 20
    b = 5.75
    c = true
    d = 'A'
    e = "Mundo"
    fmt.Println(a, b, c, d, e)

    fmt.Println("--- 1.3 Formato de identificadores ---")
    var _variable int32 = 1
    var miVariable int32 = 2
    var Variable123 int32 = 3
    fmt.Println(_variable, miVariable, Variable123)

    fmt.Println("--- 1.4 Declaración corta ---")
    x := 100
    y := 3.14
    z := true
    r := 'X'
    s := "corta"
    fmt.Println(x, y, z, r, s)

    fmt.Println("--- 1.5 Declaración sin inicializar ---")
    var sinInit1 int32
    var sinInit2 float32
    var sinInit3 bool
    var sinInit4 string
    fmt.Println(sinInit1, sinInit2, sinInit3, sinInit4)

    fmt.Println("--- 1.6 Declaración múltiple ---")
    var m1, m2 int32 = 10, 20
    fmt.Println(m1, m2)
    p, q := 30, 40
    fmt.Println(p, q)

    fmt.Println("--- 1.7 Constantes ---")
    fmt.Println(PI, MAX)

    fmt.Println("--- 1.8 Manejo de nil ---")
    var nulo int32
    fmt.Println(nulo)

    fmt.Println("--- 1.9/1.10 Comentarios ---")
    // Esto es un comentario de una línea
    /*
       Esto es un comentario
       de múltiples líneas
    */
    fmt.Println("Comentarios OK")

    fmt.Println("--- 1.11 Operaciones aritméticas ---")
    fmt.Println(10 + 5)
    fmt.Println(10 - 5)
    fmt.Println(10 * 5)
    fmt.Println(10 / 3)
    fmt.Println(10 % 3)
    fmt.Println(2.5 + 1.5)
    fmt.Println("Hola" + " " + "Mundo")

    fmt.Println("--- 1.12 Operaciones relacionales ---")
    fmt.Println(10 > 5)
    fmt.Println(10 < 5)
    fmt.Println(10 == 10)
    fmt.Println(10 != 5)
    fmt.Println(10 >= 10)
    fmt.Println(10 <= 9)

    fmt.Println("--- 1.13 Operaciones lógicas ---")
    fmt.Println(true && true)
    fmt.Println(true && false)
    fmt.Println(false || true)
    fmt.Println(!false)

    fmt.Println("--- 1.14 Cortocircuito ---")
    var cortocircuito bool = false
    cortocircuito = false && potencia(2, 3) > 0
    fmt.Println(cortocircuito)
    cortocircuito = true || potencia(2, 3) > 0
    fmt.Println(cortocircuito)

    fmt.Println("--- 1.15 Operadores de asignación ---")
    var num int32 = 10
    num += 5
    fmt.Println(num)
    num -= 3
    fmt.Println(num)
    num *= 2
    fmt.Println(num)
    num /= 4
    fmt.Println(num)

    // ===== 2. FUNCIONALIDADES INTERMEDIAS =====
    fmt.Println("")
    fmt.Println("--- 2.2 if ---")
    if a > 10 {
        fmt.Println("a es mayor que 10")
    }

    fmt.Println("--- 2.3 if else ---")
    if a > 100 {
        fmt.Println("a es mayor que 100")
    } else {
        fmt.Println("a NO es mayor que 100")
    }

    fmt.Println("--- 2.4 switch/case/default ---")
    var dia int32 = 3
    switch dia {
    case 1:
        fmt.Println("Lunes")
    case 2, 3:
        fmt.Println("Martes o Miércoles")
    case 4:
        fmt.Println("Jueves")
    default:
        fmt.Println("Otro día")
    }

    fmt.Println("--- 2.5 for clásico ---")
    for i := 0; i < 5; i++ {
        fmt.Println(i)
    }

    fmt.Println("--- 2.6 for condicional ---")
    var cuenta int32 = 3
    for cuenta > 0 {
        fmt.Println(cuenta)
        cuenta--
    }

    fmt.Println("--- 2.7 for infinito ---")
    var iter int32 = 0
    for {
        if iter >= 3 {
            break
        }
        fmt.Println("Iteración infinita:", iter)
        iter++
    }

    fmt.Println("--- 2.8 break ---")
    for i := 0; i < 10; i++ {
        if i == 5 {
            break
        }
        fmt.Println(i)
    }

    fmt.Println("--- 2.9 continue ---")
    for i := 0; i < 5; i++ {
        if i == 2 {
            continue
        }
        fmt.Println(i)
    }

    // ===== 3. FUNCIONES =====
    fmt.Println("")
    fmt.Println("--- 3.1 Función sin parámetros ---")
    imprimirArbol()

    fmt.Println("--- 3.2 Función con parámetros ---")
    vol := calcularVolumenPiramide(3.0, 6.0)
    fmt.Println("Volumen:", vol)

    fmt.Println("--- 3.3 Funciones por referencia ---")
    var val1 int32 = 10
    var val2 int32 = 20
    fmt.Println("Antes:", val1, val2)
    intercambioValores(&val1, &val2)
    fmt.Println("Después:", val1, val2)

    fmt.Println("--- 3.4 Función múltiple retorno (division) ---")
    resultado, exito := division(10, 3)
    fmt.Println("10/3 =", resultado, "éxito:", exito)
    resultado2, exito2 := division(10, 0)
    fmt.Println("10/0 =", resultado2, "éxito:", exito2)

    fmt.Println("--- 3.5 Función recursiva con un retorno ---")
    fmt.Println("2^10 =", potencia(2, 10))
    fmt.Println("3^4 =", potencia(3, 4))

    fmt.Println("--- 3.5 Función recursiva múltiple retorno (Euclides) ---")
    gcd, pasos := euclidesGCD(48, 18)
    fmt.Println("GCD(48,18) =", gcd, "pasos:", pasos)

    fmt.Println("--- 3.6 función main ---")
    fmt.Println("Estamos dentro de main()")

    fmt.Println("--- 3.7 Hoisting ---")
    fmt.Println("Las funciones fueron llamadas antes de su definición textual - OK")

    // ===== 4. FUNCIONES EMBEBIDAS =====
    fmt.Println("")
    fmt.Println("--- 4.1 fmt.Println ---")
    fmt.Println("Resultado:", 10, true, 3.14)

    fmt.Println("--- 4.2 len ---")
    var arr4 [4]int32
    fmt.Println("len(arr4):", len(arr4))
    fmt.Println("len(cadena):", len(cadena))

    fmt.Println("--- 4.3 now ---")
    var fecha string = now()
    fmt.Println("Fecha:", fecha)

    fmt.Println("--- 4.4 substr ---")
    var texto string = "Compiladores"
    var sub string = substr(texto, 0, 4)
    fmt.Println("substr:", sub)

    fmt.Println("--- 4.5 typeOf ---")
    fmt.Println("typeOf(entero):", typeOf(entero))
    fmt.Println("typeOf(decimal):", typeOf(decimal))
    fmt.Println("typeOf(bandera):", typeOf(bandera))
    fmt.Println("typeOf(caracter):", typeOf(caracter))
    fmt.Println("typeOf(cadena):", typeOf(cadena))

    // ===== 5. ARREGLOS =====
    fmt.Println("")
    fmt.Println("--- 5.1 Declaración no inicializada e inicializada ---")
    var arrVacio [3]int32
    fmt.Println(arrVacio[0], arrVacio[1], arrVacio[2])
    var arrInit [3]int32 = [3]int32{10, 20, 30}
    fmt.Println(arrInit[0], arrInit[1], arrInit[2])

    fmt.Println("--- 5.2 Arreglos de tipos estáticos ---")
    var arrStr [2]string = [2]string{"Ana", "Luis"}
    fmt.Println(arrStr[0], arrStr[1])
    var arrBool [2]bool = [2]bool{true, false}
    fmt.Println(arrBool[0], arrBool[1])
    var arrRune [3]rune = [3]rune{'a', 'b', 'c'}
    fmt.Println(arrRune[0], arrRune[1], arrRune[2])
    var arrFloat [2]float32 = [2]float32{1.1, 2.2}
    fmt.Println(arrFloat[0], arrFloat[1])

    fmt.Println("--- 5.3 Acceso y modificación ---")
    var nums [4]int32
    nums[0] = 100
    nums[1] = 200
    nums[2] = 300
    nums[3] = 400
    fmt.Println(nums[0], nums[1], nums[2], nums[3])

    fmt.Println("--- 5.4 Multidimensional ---")
    var mat [2][3]int32
    mat[0][0] = 1
    mat[0][1] = 2
    mat[0][2] = 3
    mat[1][0] = 4
    mat[1][1] = 5
    mat[1][2] = 6
    for i := 0; i < 2; i++ {
        for j := 0; j < 3; j++ {
            fmt.Println(mat[i][j])
        }
    }

    fmt.Println("--- 5.5 Acceso y Modificación multidimensional ---")
    var grid [2][2]int32
    grid[0][0] = 10
    grid[0][1] = 20
    grid[1][0] = 30
    grid[1][1] = 40
    fmt.Println(grid[0][0], grid[0][1])
    fmt.Println(grid[1][0], grid[1][1])

    // ===== RESUMEN =====
    fmt.Println("")
    fmt.Println("========================================")
    fmt.Println("  PRUEBA COMPLETA FINALIZADA")
    fmt.Println("========================================")
}
